# Port du serveur Express (défaut: 3000)
PORT=3000
# Requis pour POST /chat — le backend utilise Google Gemini
# Obtiens une clé API via Google Cloud Console (Generative Language API)
# Ajoute la clé ici : GEMINI_API_KEY=YOUR_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY# Optionnel — timeout API Gemini en ms (défaut: 30000)
# GEMINI_TIMEOUT_MS=30000

# Optionnel — si Node ne résout pas les domaines sous Windows alors que
# nslookup fonctionne avec 1.1.1.1, force les serveurs DNS pour ce process :
# DNS_SERVERS=1.1.1.1,1.0.0.1

# Non utilisé par /chat (réservé app Flutter ou anciennes configs)
# HF_TOKEN=
# GROQ_API_KEY=
MASAKHANE_BACKEND_URL=http://localhost:3000